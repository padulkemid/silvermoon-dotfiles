[user]
	signingkey =
	name = Fadhil Muhammad
	email = 
[commit]
	gpgsign = true
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[pull]
	rebase = true
[gpg]
	program = /opt/homebrew/bin/gpg
[rerere]
	enabled = true
[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true  # use n and N to move between diff sections
[merge]
  conflictStyle = zdiff3


